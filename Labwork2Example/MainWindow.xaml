<Window x:Class="Labwork2Example.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Labwork2Example"
        mc:Ignorable="d"
        Title="Example for the laboratory work #2" Height="470" Width="700" MinHeight="470">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="IsEnabled" Value="False"/>
        </Style>
    </Window.Resources>
    <Grid ClipToBounds="True">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        <Label Grid.Row="1" Margin="5,0,0,0">Matrix 1</Label>
        <DataGrid x:Name="DataGrid1" Grid.Column="0" Grid.Row="2" AutoGenerateColumns="True" SelectionUnit="CellOrRowHeader" CanUserAddRows="False" Margin="5,0,0,5" LoadingRow="DataGrid_LoadingRow"/>
        <Label Grid.Column="0" Grid.Row="3" Margin="5,0,0,0">Matrix 2</Label>
        <DataGrid x:Name="DataGrid2" Grid.Column="0" Grid.Row="4" Grid.RowSpan="2" AutoGenerateColumns="True" SelectionUnit="CellOrRowHeader" CanUserAddRows="False" Margin="5,0,0,10" LoadingRow="DataGrid_LoadingRow"/>
        <StackPanel Grid.Column="1" Grid.Row="1" Grid.RowSpan="4" Margin="0,30,0,0">
            <Button x:Name="LoadMatrix1Button" Content="Load matrix 1" Click="LoadMatrix_Click" IsEnabled="True"></Button>
            <Button x:Name="LoadMatrix2Button" Content="Load matrix 2" Click="LoadMatrix_Click" IsEnabled="True"></Button>
            <Button x:Name="SaveMatrix1Button" Content="Save matrix 1" Click="SaveMatrix_Click"></Button>
            <Button x:Name="SaveMatrix2Button" Content="Save matrix 2"></Button>
            <Button x:Name="Task1Button" Content="Task 1" Click="Task1_Click"></Button>
            <Button x:Name="Task2Button" Content="Task 2" Click="Task2_Click"></Button>
            <Button x:Name="Task3Button" Content="Task 3" Click="Task3_Click"></Button>
        </StackPanel>
        <CheckBox Grid.Row="5" Grid.Column="1" x:Name="IdenticalSizesCheckBox" IsChecked="True" Margin="10,10,0,10" VerticalAlignment="Bottom">Identical matrix sizes required</CheckBox>
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem x:Name="LoadMatrix1MenuItem" Header="Load matrix 1" Click="LoadMatrix_Click"/>
                <MenuItem x:Name="LoadMatrix2MenuItem" Header="Load matrix 2" Click="LoadMatrix_Click"/>
                <Separator/>
                <MenuItem x:Name="SaveMatrix1MenuItem" IsEnabled="False" Header="Save matrix 1" Click="SaveMatrix_Click"/>
                <MenuItem x:Name="SaveMatrix2MenuItem" IsEnabled="False" Header="Save matrix 2" Click="SaveMatrix_Click"/>
                <Separator/>
                <MenuItem Header="Exit" Click="Exit_Click"/>
            </MenuItem>

            <MenuItem Header="_Tasks" IsEnabled="True">
                <MenuItem x:Name="Task1MenuItem" Header="Task 1" IsEnabled="False" Click="Task1_Click"/>
                <MenuItem x:Name="Task2MenuItem" Header="Task 2" IsEnabled="False" Click="Task2_Click"/>
                <MenuItem x:Name="Task3MenuItem" Header="Task 3" IsEnabled="False" Click="Task3_Click"/>
            </MenuItem>
        </Menu>
    </Grid>
</Window>
